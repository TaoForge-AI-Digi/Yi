{
    "name": "mcp_manager",
    "description": "MCP 服务器管理。list: 列出所有 MCP 服务器 | view: 查看服务器配置 | create: 创建新的 MCP 服务器 | edit: 修改已有服务器 | delete: 删除服务器",
    "source": "builtin",
    "parameters": {
        "type": "object",
        "properties": {
            "action": {
                "type": "string",
                "enum": ["list", "view", "create", "edit", "delete"],
                "description": "操作类型"
            },
            "name": {
                "type": "string",
                "description": "服务器名称（view/create/edit/delete 必填）"
            },
            "command": {
                "type": "string",
                "description": "启动命令（create 必填, edit 选填）"
            },
            "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "命令行参数（create/edit 选填）"
            },
            "env": {
                "type": "object",
                "additionalProperties": { "type": "string" },
                "description": "环境变量（create/edit 选填）"
            }
        },
        "required": ["action"]
    },
    "version": "1.0.0",
    "tags": ["system"],
    "dangerous": false
}
